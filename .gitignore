# Python bytecode and test caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.codegraph/
.coverage
htmlcov/

# Local environments and secrets
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# Editor and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs and temporary files
*.log
logs/
tmp/
temp/
.tmp/

# Root-level generated outputs and local service volumes outside runtime_assets
milvus_data/
/volumes/
/output/
/outputs/
/uploads/

# Runtime assets are local generated/provisioned state. Keep only explicit
# directory placeholders so the expected tree can be recreated without tracking
# model metadata, generated outputs, caches, uploads, or service volumes.
runtime_assets/**
!runtime_assets/**/
!runtime_assets/**/.gitkeep

# Large model artifacts should be provisioned outside Git or through Git LFS.
*.pt
*.pth
*.bin
*.safetensors
*.onnx
*.ckpt
*.pdiparams
*.pdmodel
*.pdparams

# Downloaded dataset archives
qa/dataset/**/*.tar.gz
qa/dataset/**/*.tgz
